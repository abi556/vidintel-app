# YouTube Data API v3 key
# Get one at https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Base URL for OG meta tags (optional, defaults to Vercel URL)
# NEXT_PUBLIC_BASE_URL=https://vidintel-app.vercel.app

# Optional: Upstash Redis — enables per-IP rate limiting on POST /api/channel (recommended for production)
# https://console.upstash.com/
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# RATE_LIMIT_CHANNEL_PER_MINUTE=60
